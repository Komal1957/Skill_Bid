<div id="<%= dom_id(message) %>" class="flex w-full mb-4 <%= 'justify-end' if message.user == message.request.client %>">
  
  <div class="flex flex-col <%= message.user == message.request.client ? 'items-end' : 'items-start' %> max-w-[80%]">
    
    <!-- Name Label -->
    <span class="text-xs text-gray-500 mb-1">
      <%= message.user.email.split('@')[0] %> 
      <% if message.user == message.request.client %>(Client)<% else %>(Freelancer)<% end %>
    </span>

    <!-- Bubble -->
    <div class="px-4 py-2 rounded-lg shadow-sm text-sm break-words
      <%= if message.user == message.request.client 
            'bg-indigo-600 text-white rounded-br-none' 
          else 
            'bg-gray-200 text-gray-800 rounded-bl-none' 
          end %>">
      <%= message.content %>
    </div>
  </div>
</div>