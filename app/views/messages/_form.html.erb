<%= form_with(model: [request, message], data: { turbo: true }) do |f| %>
  <div class="flex gap-2">
    <%= f.text_field :content, placeholder: "Type a message...", class: "flex-1 border rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500", autocomplete: "off" %>
    <%= f.submit "Send", class: "bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 font-medium" %>
  </div>
<% end %>