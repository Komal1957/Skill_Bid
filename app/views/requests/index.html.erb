<div class="container mx-auto p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold">Open Requests</h1>
    <% if current_user.is_a?(Client) %>
      <%= link_to "Post a Request", new_request_path, class: "bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700" %>
    <% end %>
  </div>

  <div class="grid gap-6">
    <% @requests.each do |request| %>
      <div class="bg-white p-6 rounded-lg shadow border border-gray-200">
        <div class="flex justify-between items-start">
          <div>
            <span class="text-xs font-bold text-indigo-600 uppercase"><%= request.category.name %></span>
            <h2 class="text-xl font-bold mt-1"><%= link_to request.title, request_path(request), class: "hover:underline" %></h2>
            <p class="text-gray-600 mt-2 line-clamp-2"><%= request.description %></p>
          </div>
          <div class="text-right">
            <div class="text-2xl font-bold text-green-600">$<%= request.budget %></div>
            <div class="text-sm text-gray-500">Budget</div>
          </div>
        </div>
        
        <div class="mt-4 flex justify-between items-center text-sm text-gray-500">
          <span>Posted by <%= request.client.email.split('@')[0] %></span>
          <span>Bids: <%= request.bids.count %></span>
        </div>
      </div>
    <% end %>
  </div>
  
</div>