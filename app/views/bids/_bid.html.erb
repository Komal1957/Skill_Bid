<div id="<%= dom_id bid %>" class="border-b py-4">
  <p class="font-bold text-lg"><%= number_to_currency(bid.amount) %></p>
  <p class="text-gray-600"><%= bid.description %></p>
  <p class="text-xs text-gray-400">By: <%= bid.user.email %></p>

  <% if bid.user == current_user %>
    <div class="mt-2">
      <%= link_to "Edit", edit_request_bid_path(bid), class: "text-blue-500" %>
    </div>
  <% end %> <%# <-- ENSURE THIS END IS HERE %>
</div>
