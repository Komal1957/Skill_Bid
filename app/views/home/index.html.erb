<div class="min-h-screen bg-gray-50 flex flex-col justify-center items-center">
    <div class="text-center">
        <h1 class"text-5xl font-bold text-indigo-600 mb-4">SkillBid</h1>
        <p class="text-xl text-gray-700 mb-8">The Real-Time Micro-Freelance Auction Platform</p>

        <div class="space-x-4">
            <% if user_signed_in? %>
                <div class="p-4 bg--white rounded shadow">
                    <h2 class="text-2xl mb-2">Welcome,<span class"capitalize"><%= current_user.type %></span>!</h2>

                    <p> Email: <%= current_user.email %></p>
                    <%= link_to "Logout", destroy_user_session_path, data: {turbo_method: :delete}, class: "text-red-500 hover:underline" %>
                </div>

                <div class="text-center">
                    <!-- Show avatar if it exists -->
                    <% if current_user.avatar.attached? %>
                        <%= image_tag current_user.avatar, class: "w-16 h-16 rounded-full mx-auto mb-2 border-2 border-indigo-500" %>
                    <% end %>

                    <h1 class="text-5xl font-bold text-indigo-600 mb-4">SkillBid</h1>
                    <p class="text-xl text-gray-700 mb-8">Welcome, <span class="capitalize"><%= current_user.type %></span>!</p>
  
  
                </div>
            <% else %>
                <%= link_to "Login as Client", new_user_session_path, class: "bg-indigo-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-indigo-700" %>
                <%= link_to "Sign Up", new_user_registration_path, class: "bg-white text-indigo-600 border border-indigo-600 px-6 py-3 rounded-lg font-semibold hover:bg-indigo-50" %>
            <% end %>

            
    </div>
  </div>
</div>
